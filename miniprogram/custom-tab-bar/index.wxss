.tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 22rpx;
}

.tab-item.active {
  color: #6c63ff;
}

.tab-item .icon {
  font-size: 44rpx;
  margin-bottom: 6rpx;
}

/* 图标样式 - 使用 Unicode 符号 */
.tab-item .icon-user::before { content: '👤'; }
.tab-item .icon-user-fill::before { content: '👤'; }
.tab-item .icon-chart::before { content: '🏆'; }
.tab-item .icon-chart-fill::before { content: '🏆'; }
.tab-item .icon-calendar::before { content: '👨‍🏫'; }
.tab-item .icon-calendar-fill::before { content: '👨‍🏫'; }

.tab-item .icon::before {
  font-size: 48rpx;
}

.tab-item .icon-user::before,
.tab-item .icon-user-fill::before { content: '👤'; font-size: 42rpx; }
.tab-item .icon-chart::before,
.tab-item .icon-chart-fill::before { content: '🏆'; font-size: 42rpx; }
.tab-item .icon-calendar::before,
.tab-item .icon-calendar-fill::before { content: '👨‍🏫'; font-size: 42rpx; }
