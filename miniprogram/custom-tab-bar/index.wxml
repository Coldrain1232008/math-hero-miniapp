<view class="tab-bar" wx:if="{{role === 'student'}}">
  <view
    wx:for="{{list}}"
    wx:key="text"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <text class="icon icon-{{item.iconName}}"></text>
    <text class="text">{{item.text}}</text>
  </view>
</view>

<view class="tab-bar" wx:if="{{role === 'teacher'}}">
  <view
    wx:for="{{list}}"
    wx:key="text"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <text class="icon icon-{{item.iconName}}"></text>
    <text class="text">{{item.text}}</text>
  </view>
</view>
