/* pages/ranking/ranking.wxss */
.page-bg { background: #f0f0f8; min-height: 100vh; padding-bottom: 120rpx; }

/* 领奖台 */
.podium-area {
  padding: 48rpx 32rpx 0;
  border-radius: 0 0 40rpx 40rpx;
}

.podium-title {
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 48rpx;
  letter-spacing: 4rpx;
}

.podium-row {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 16rpx;
  padding-bottom: 0;
}

.podium-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.podium-crown { font-size: 36rpx; margin-bottom: 4rpx; }

.podium-avatar { font-size: 60rpx; line-height: 1; }
.podium-name { font-size: 24rpx; color: #fff; margin: 8rpx 0 4rpx; font-weight: 600; max-width: 120rpx; text-align: center; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.podium-level { font-size: 20rpx; color: rgba(255,255,255,0.6); margin-bottom: 12rpx; }

.podium-stand {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx 12rpx 0 0;
  width: 120rpx;
}

.stand-1 { height: 100rpx; background: linear-gradient(180deg, #f6d365, #fda085); }
.stand-2 { height: 72rpx; background: linear-gradient(180deg, #a0aec0, #718096); }
.stand-3 { height: 56rpx; background: linear-gradient(180deg, #ed8936, #c05621); }

/* 我的排名条 */
.my-rank-bar {
  display: flex;
  align-items: center;
  background: #fff;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  border: 2rpx solid #6c63ff;
  box-shadow: 0 4rpx 16rpx rgba(108,99,255,0.15);
  gap: 16rpx;
}

.my-rank-label { font-size: 22rpx; color: #6c63ff; }
.my-rank-num { font-size: 36rpx; font-weight: bold; color: #6c63ff; }
.my-rank-name { font-size: 28rpx; font-weight: bold; color: #333; flex: 1; }
.my-rank-lv { font-size: 22rpx; color: #f59e0b; font-weight: 600; }
.my-rank-exp { font-size: 22rpx; color: #999; }

/* 榜单列表 */
.rank-list { padding: 0 24rpx; }

.rank-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
  gap: 16rpx;
}

.rank-item.is-me {
  border: 2rpx solid #6c63ff;
  background: #f5f3ff;
}

.rank-no {
  width: 60rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  color: #bbb;
  flex-shrink: 0;
}

.rank-no.top3 { font-size: 36rpx; }

.rank-avatar { font-size: 56rpx; flex-shrink: 0; }

.rank-info { flex: 1; min-width: 0; }

.rank-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.rank-name { font-size: 28rpx; font-weight: 600; color: #333; }

.rank-title-text {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  margin-left: 12rpx;
}

.rank-title {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  color: #92400e;
}

.title-icon { font-size: 22rpx; }
.title-name { font-size: 20rpx; font-weight: 600; }

.rank-bar-bg {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.rank-bar-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.6s ease;
}

.rank-right { text-align: right; flex-shrink: 0; }

.rank-lv-badge {
  background: linear-gradient(135deg, #f6d365, #fda085);
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  display: inline-block;
}

.rank-exp { font-size: 22rpx; color: #999; display: block; }
