<!-- pages/teacher/teacher.wxml -->
<view class="page-bg">
  <view class="teacher-header gradient-bg">
    <text class="teacher-title">教师管理台</text>
    <text class="teacher-class">{{className}}</text>
  </view>

  <!-- 班级统计 -->
  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-num">{{stats.total}}</text>
      <text class="stat-label">学生总数</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{stats.avgLevel}}</text>
      <text class="stat-label">平均等级</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{stats.maxLevel}}</text>
      <text class="stat-label">最高等级</text>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goScore">
      <view class="menu-icon" style="background:#e0e7ff">⚡</view>
      <view class="menu-info">
        <text class="menu-title">课堂打分</text>
        <text class="menu-desc">给学生+1经验值，记录课堂表现</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goUpload">
      <view class="menu-icon" style="background:#dcfce7">📊</view>
      <view class="menu-info">
        <text class="menu-title">导入成绩</text>
        <text class="menu-desc">上传 Excel，批量发放考试经验</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goClass">
      <view class="menu-icon" style="background:#fef3c7">👥</view>
      <view class="menu-info">
        <text class="menu-title">班级管理</text>
        <text class="menu-desc">查看学生列表，管理角色信息</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goTask">
      <view class="menu-icon" style="background:#fae8ff">⭐</view>
      <view class="menu-info">
        <text class="menu-title">任务管理</text>
        <text class="menu-desc">发布特殊任务，管理任务池</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 近期操作日志 -->
  <view class="card log-section">
    <view class="card-title">近期操作</view>
    <view wx:if="{{recentLogs.length === 0}}" class="empty-log">暂无记录</view>
    <view wx:for="{{recentLogs}}" wx:key="_id" class="log-item {{item.undone ? 'log-undone' : ''}}" bindtap="showLogDetail" data-index="{{index}}">
      <view class="log-main">
        <text class="log-type-tag">{{item.typeLabel}}</text>
        <text class="log-summary">{{item.studentName || '学生'}} {{item.amount > 0 ? '+' : ''}}{{item.amount}} EXP</text>
      </view>
      <view class="log-meta">
        <text class="log-time">{{item.timeStr}}</text>
        <text wx:if="{{item.undone}}" class="undone-badge">已撤回</text>
        <text wx:else class="arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 操作详情弹窗 -->
  <view wx:if="{{showLogDetail}}" class="modal-mask" bindtap="hideLogDetail">
    <view class="modal-box log-detail-modal" catchtap="preventBubble">
      <view class="detail-header">
        <text class="detail-type">{{selectedLog.typeLabel}}</text>
        <text class="detail-time">{{selectedLog.timeStr}}</text>
      </view>
      
      <view class="detail-body">
        <view class="detail-row">
          <text class="detail-label">学生</text>
          <text class="detail-value">{{selectedLog.studentName || '未知'}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">经验值</text>
          <text class="detail-value {{selectedLog.amount > 0 ? 'exp-positive' : 'exp-negative'}}">{{selectedLog.amount > 0 ? '+' : ''}}{{selectedLog.amount}} EXP</text>
        </view>
        <view class="detail-row" wx:if="{{selectedLog.baseExp}}">
          <text class="detail-label">基础奖励</text>
          <text class="detail-value">+{{selectedLog.baseExp}} EXP</text>
        </view>
        <view class="detail-row" wx:if="{{selectedLog.bonusExp}}">
          <text class="detail-label">天赋加成</text>
          <text class="detail-value exp-positive">+{{selectedLog.bonusExp}} EXP</text>
        </view>
        <view class="detail-desc">
          <text class="detail-label">说明</text>
          <text class="detail-desc-text">{{selectedLog.description || selectedLog.desc || '-'}}</text>
        </view>
      </view>
      
      <view class="detail-footer">
        <button class="btn-secondary" bindtap="hideLogDetail">返回</button>
        <button wx:if="{{selectedLog.canUndo}}" class="btn-danger" bindtap="undoSelectedLog">撤回</button>
      </view>
    </view>
  </view>
</view>
