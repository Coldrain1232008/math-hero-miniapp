/* pages/teacher/teacher.wxss */
.page-bg { background: #f0f0f8; min-height: 100vh; padding-bottom: 120rpx; }

.teacher-header {
  padding: 60rpx 40rpx 48rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.teacher-title { font-size: 44rpx; font-weight: bold; color: #fff; display: block; margin-bottom: 8rpx; }
.teacher-class { font-size: 26rpx; color: rgba(255,255,255,0.6); display: block; }

/* 统计行 */
.stats-row {
  display: flex;
  margin: 24rpx 24rpx 0;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.stat-num { font-size: 48rpx; font-weight: bold; color: #6c63ff; display: block; }
.stat-label { font-size: 22rpx; color: #999; margin-top: 6rpx; display: block; }

/* 菜单 */
.menu-list { margin: 24rpx 24rpx 0; }

.menu-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  gap: 24rpx;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.menu-info { flex: 1; }
.menu-title { font-size: 30rpx; font-weight: bold; color: #333; display: block; margin-bottom: 6rpx; }
.menu-desc { font-size: 24rpx; color: #999; display: block; }
.menu-arrow { font-size: 48rpx; color: #ccc; }

/* 操作日志 */
.card { background: #fff; border-radius: 24rpx; padding: 36rpx; margin: 24rpx 24rpx 0; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); }
.card-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 28rpx; }
.empty-log { color: #bbb; font-size: 26rpx; text-align: center; padding: 32rpx 0; }

.log-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 12rpx;
}
.log-row:last-child { border: none; }
.log-type-tag { font-size: 20rpx; color: #6c63ff; background: #f0eeff; padding: 3rpx 10rpx; border-radius: 6rpx; flex-shrink: 0; }
.log-text { flex: 1; font-size: 24rpx; color: #555; }
.log-time { font-size: 20rpx; color: #bbb; flex-shrink: 0; }
