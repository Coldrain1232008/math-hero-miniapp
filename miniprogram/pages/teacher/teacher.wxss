/* pages/teacher/teacher.wxss */
.page-bg { background: #f0f0f8; min-height: 100vh; padding-bottom: 120rpx; }

.teacher-header {
  padding: 60rpx 40rpx 48rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.teacher-title { font-size: 44rpx; font-weight: bold; color: #fff; display: block; margin-bottom: 8rpx; }
.teacher-class { font-size: 26rpx; color: rgba(255,255,255,0.6); display: block; }

/* 统计行 */
.stats-row {
  display: flex;
  margin: 24rpx 24rpx 0;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.stat-num { font-size: 48rpx; font-weight: bold; color: #6c63ff; display: block; }
.stat-label { font-size: 22rpx; color: #999; margin-top: 6rpx; display: block; }

/* 菜单 */
.menu-list { margin: 24rpx 24rpx 0; }

.menu-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  gap: 24rpx;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.menu-info { flex: 1; }
.menu-title { font-size: 30rpx; font-weight: bold; color: #333; display: block; margin-bottom: 6rpx; }
.menu-desc { font-size: 24rpx; color: #999; display: block; }
.menu-arrow { font-size: 48rpx; color: #ccc; }

/* 操作日志 */
.card { background: #fff; border-radius: 24rpx; padding: 36rpx; margin: 24rpx 24rpx 0; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); }
.card-title { font-size: 30rpx; font-weight: bold; color: #333; margin-bottom: 28rpx; }
.empty-log { color: #bbb; font-size: 26rpx; text-align: center; padding: 32rpx 0; }

/* 操作日志 - 简洁列表 */
.log-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.log-item:last-child { border: none; }
.log-item.log-undone { opacity: 0.5; }

.log-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.log-type-tag {
  font-size: 20rpx;
  color: #6c63ff;
  background: #f0eeff;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.log-summary {
  font-size: 28rpx;
  color: #333;
}

.log-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.log-time {
  font-size: 22rpx;
  color: #999;
}

.undone-badge {
  font-size: 20rpx;
  color: #999;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 详情弹窗 */
.log-detail-modal {
  max-width: 600rpx;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  padding: 40rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
  flex-shrink: 0;
}

.detail-type {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.detail-time {
  font-size: 24rpx;
  color: #999;
}

.detail-body {
  flex: 1;
  overflow-y: auto;
  margin-bottom: 32rpx;
  padding-right: 10rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
}

.detail-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.detail-desc {
  padding: 20rpx 0;
}

.detail-desc-text {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
  background: #f8f8fc;
  padding: 20rpx;
  border-radius: 12rpx;
}

.exp-positive { color: #10b981; }
.exp-negative { color: #ef4444; }

.detail-footer {
  display: flex;
  gap: 20rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
  flex-shrink: 0;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.btn-secondary {
  flex: 1;
  background: #f0f0f0;
  color: #666;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  border: none;
  margin: 0;
}

.btn-danger {
  flex: 1;
  background: #ef4444;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  border: none;
  margin: 0;
}
