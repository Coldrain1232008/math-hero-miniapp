/* pages/teacher-class/teacher-class.wxss */
.page-bg { background: #f0f0f8; min-height: 100vh; padding-bottom: 80rpx; }

/* 班级信息卡片 */
.class-info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.class-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}
.key-row { margin-bottom: 24rpx; }
.key-item { margin-bottom: 16rpx; }
.key-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}
.key-value-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #f8f8fc;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
}
.key-value {
  font-size: 30rpx;
  font-weight: bold;
  color: #6c63ff;
  font-family: 'Menlo', 'Consolas', monospace;
  letter-spacing: 4rpx;
  flex: 1;
}
.key-value.teacher-key { color: #f59e0b; }
.btn-copy-sm {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  background: #e8e5ff;
  color: #6c63ff;
  border-radius: 20rpx;
  border: none;
  margin: 0;
  line-height: 1.6;
  white-space: nowrap;
}

.action-row {
  display: flex;
  gap: 16rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}
.btn-action {
  flex: 1;
  font-size: 26rpx;
  padding: 16rpx 0;
  background: #f0f4ff;
  color: #6c63ff;
  border-radius: 12rpx;
  border: none;
  margin: 0;
  text-align: center;
}
.btn-action:active { background: #e0e5ff; }

/* 列表头 */
.header-bar { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx 0; }
.total-label { font-size: 26rpx; color: #888; }
.btn-add { background: #6c63ff; color: #fff; border-radius: 40rpx; font-size: 26rpx; padding: 12rpx 32rpx; border: none; margin: 0; }

/* 学生列表 */
.student-list { padding: 0 24rpx; }
.s-card { background: #fff; border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.s-top { display: flex; align-items: center; gap: 20rpx; margin-bottom: 20rpx; }
.s-avatar-circle { width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
.s-avatar-icon { font-size: 40rpx; }
.s-main { flex: 1; }
.s-id-name-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 4rpx; }
.s-student-id { font-size: 24rpx; color: #6c63ff; font-weight: 600; background: #f0f4ff; padding: 2rpx 10rpx; border-radius: 6rpx; }
.s-real-name { font-size: 30rpx; font-weight: bold; color: #333; }
.s-hero-name { font-size: 26rpx; color: #666; display: block; margin-bottom: 6rpx; }
.s-hero-name.pending { color: #999; font-style: italic; }
.s-talent-tag { font-size: 22rpx; padding: 3rpx 12rpx; background: rgba(0,0,0,0.04); border-radius: 8rpx; display: inline-block; }
.s-level-badge { background: linear-gradient(135deg, #f6d365, #fda085); color: #fff; font-size: 22rpx; font-weight: bold; padding: 6rpx 16rpx; border-radius: 20rpx; }

.s-attrs { display: flex; justify-content: space-between; background: #f8f8fc; border-radius: 12rpx; padding: 16rpx 20rpx; margin-bottom: 16rpx; }
.mini-attr { display: flex; flex-direction: column; align-items: center; }
.mini-attr text { font-size: 20rpx; font-weight: 600; }
.mini-val { font-size: 24rpx; color: #333; margin-top: 4rpx; }

.s-key-section { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; padding: 12rpx 16rpx; background: #f0f4ff; border-radius: 10rpx; }
.s-key-label { font-size: 22rpx; color: #888; white-space: nowrap; }
.s-key-box { display: flex; align-items: center; gap: 12rpx; flex: 1; }
.s-key-text { font-size: 28rpx; font-weight: bold; color: #6c63ff; font-family: 'Menlo', 'Consolas', monospace; letter-spacing: 4rpx; }
.s-key-text.no-key { color: #ccc; font-size: 24rpx; }
.btn-copy { font-size: 22rpx; padding: 6rpx 20rpx; background: #6c63ff; color: #fff; border-radius: 20rpx; border: none; margin: 0; line-height: 1.6; }

.s-footer { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8rpx; }
.s-exp { font-size: 24rpx; color: #999; }
.s-actions { display: flex; gap: 12rpx; }
.btn-sm { font-size: 22rpx; padding: 10rpx 20rpx; border-radius: 30rpx; margin: 0; border: none; white-space: nowrap; line-height: 1.4; }
.btn-reroll { background: #fef3c7; color: #b45309; }
.btn-delete { background: #ef4444; color: #fff; }

/* 弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 100;
  display: flex; align-items: center; justify-content: center;
}
.modal-box { background: #fff; border-radius: 24rpx; padding: 48rpx 40rpx; width: 80%; }
.modal-title { font-size: 34rpx; font-weight: bold; color: #333; display: block; margin-bottom: 12rpx; }
.modal-desc { font-size: 24rpx; color: #999; display: block; margin-bottom: 28rpx; }
.name-textarea { width: 100%; height: 200rpx; background: #f8f8fc; border-radius: 12rpx; padding: 20rpx; font-size: 28rpx; color: #333; box-sizing: border-box; }
.modal-btns { display: flex; gap: 20rpx; margin-top: 32rpx; justify-content: flex-end; }
.btn-secondary { background: transparent; color: #6c63ff; border: 2rpx solid #6c63ff; border-radius: 40rpx; font-size: 28rpx; padding: 14rpx 36rpx; }
.btn-primary { background: #6c63ff; color: #fff; border-radius: 40rpx; font-size: 28rpx; padding: 14rpx 36rpx; border: none; }
