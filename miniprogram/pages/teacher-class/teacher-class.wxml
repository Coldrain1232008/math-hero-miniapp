<!-- pages/teacher-class/teacher-class.wxml -->
<view class="page-bg">

  <!-- 班级信息区 -->
  <view class="class-info-card">
    <view class="class-name">{{classInfo.name || '我的班级'}}</view>

    <view class="key-row">
      <view class="key-item">
        <text class="key-label">班级密钥（给学生）</text>
        <view class="key-value-box">
          <text class="key-value">{{classInfo.studentKey || '-'}}</text>
          <button class="btn-copy-sm" catchtap="copyText" data-text="{{classInfo.studentKey}}" data-label="班级密钥">复制</button>
        </view>
      </view>
      <view class="key-item">
        <text class="key-label">教师密钥</text>
        <view class="key-value-box">
          <text class="key-value teacher-key">{{classInfo.teacherKey || '-'}}</text>
          <button class="btn-copy-sm" catchtap="copyText" data-text="{{classInfo.teacherKey}}" data-label="教师密钥">复制</button>
        </view>
      </view>
    </view>

    <view class="action-row">
      <button class="btn-action" bindtap="fixKeys">🔑 补发密钥</button>
      <button class="btn-action" bindtap="exportKeys">📋 导出密钥</button>
      <button class="btn-action task-btn" bindtap="showTaskDialog">
        📋 任务确认
        <text class="task-badge" wx:if="{{pendingTaskCount > 0}}">{{pendingTaskCount}}</text>
      </button>
    </view>
  </view>

  <!-- 学生列表 -->
  <view class="header-bar">
    <text class="total-label">共 {{students.length}} 名学生</text>
    <button class="btn-add" bindtap="showAddDialog">+ 导入名单</button>
  </view>

  <view class="student-list">
    <view wx:for="{{students}}" wx:key="_id" class="s-card">
      <view class="s-top">
        <view class="s-avatar-circle" style="background-color: {{item.avatarColor || '#999'}}">
          <text class="s-avatar-icon">{{item.avatarIcon || '🧙'}}</text>
        </view>
        <view class="s-main">
          <!-- 显示学号+姓名+角色名 -->
          <view class="s-id-name-row">
            <text class="s-student-id" wx:if="{{item.studentId}}">{{item.studentId}}</text>
            <text class="s-real-name">{{item.realName || '-'}}</text>
          </view>
          <text class="s-hero-name" wx:if="{{item.heroName}}">角色：{{item.heroName}}</text>
          <text class="s-hero-name pending" wx:else>角色：未创建</text>
          <view class="s-talent-tag" style="color:{{item.talentColor}}">{{item.talentName}}</view>
        </view>
        <view class="s-level-badge">Lv.{{item.level}}</view>
      </view>

      <view class="s-attrs">
        <view wx:for="{{item.attrDisplay}}" wx:for-item="attr" wx:key="name" class="mini-attr">
          <text style="color:{{attr.color}}">{{attr.name}}</text>
          <text class="mini-val">{{attr.val}}</text>
        </view>
      </view>

      <!-- 个人密钥 -->
      <view class="s-key-section">
        <view class="s-key-label">个人密钥：</view>
        <view class="s-key-box">
          <text class="s-key-text" wx:if="{{item.studentKey}}">{{item.studentKey}}</text>
          <text class="s-key-text no-key" wx:else>未生成</text>
          <button wx:if="{{item.studentKey}}" class="btn-copy" catchtap="copyKey" data-key="{{item.studentKey}}" data-name="{{item.realName}}">复制</button>
        </view>
      </view>

      <!-- 经验值显示 -->
      <view class="s-exp-row">
        <text class="s-exp-label">总经验值</text>
        <text class="s-exp-value">{{item.totalExp}} EXP</text>
      </view>
      
      <!-- 操作按钮 -->
      <view class="s-actions-row">
        <button class="btn-sm btn-reroll" catchtap="grantReroll" data-id="{{item._id}}" data-name="{{item.realName}}">🎲 重置</button>
        <button class="btn-sm btn-delete" catchtap="permanentDelete" data-id="{{item._id}}" data-name="{{item.realName}}">🗑️ 删除</button>
      </view>
    </view>
  </view>

  <!-- 导入名单弹窗 -->
  <view wx:if="{{showAdd}}" class="modal-mask" bindtap="hideAddDialog">
    <view class="modal-box" catchtap="preventBubble">
      <text class="modal-title">批量导入学生</text>
      <text class="modal-desc">每行一个学生，格式：学号 姓名 或 学号,姓名</text>
      <textarea
        class="name-textarea"
        placeholder="20240101 张三&#10;20240102 李四&#10;20240103 王五"
        value="{{nameInput}}"
        bindinput="onNameInput"
        maxlength="1000"
      />
      <view class="modal-btns">
        <button class="btn-secondary" bindtap="hideAddDialog">取消</button>
        <button class="btn-primary" bindtap="importNames" loading="{{addLoading}}">导入</button>
      </view>
    </view>
  </view>

  <!-- 任务确认弹窗 -->
  <view wx:if="{{showTaskConfirm}}" class="modal-mask" bindtap="hideTaskDialog">
    <view class="modal-box task-modal" catchtap="preventBubble">
      <view class="modal-header">
        <text class="modal-title">任务确认</text>
        <text class="modal-subtitle">待确认 {{pendingTasks.length}} 个任务</text>
      </view>
      
      <scroll-view scroll-y class="task-list">
        <view wx:if="{{pendingTasks.length === 0}}" class="task-empty">
          <text>暂无待确认任务</text>
        </view>
        <view wx:for="{{pendingTasks}}" wx:key="_id" class="task-card">
          <!-- 头部：学生信息 -->
          <view class="task-header">
            <view class="task-student-info">
              <text class="task-student-name">{{item.studentName}}</text>
              <text class="task-student-id" wx:if="{{item.studentNo}}">{{item.studentNo}}</text>
            </view>
            <text class="task-submit-time">{{item.submitTimeStr}}</text>
          </view>
          
          <!-- 中部：任务内容 -->
          <view class="task-body">
            <text class="task-title">{{item.title}}</text>
            <text class="task-desc">{{item.desc}}</text>
          </view>
          
          <!-- 底部：经验值和操作 -->
          <view class="task-footer">
            <view class="task-reward">
              <text class="reward-label">奖励</text>
              <text class="reward-value">+{{item.expReward}} EXP</text>
            </view>
            <view class="task-actions">
              <button class="btn-task-reject" catchtap="rejectTask" data-id="{{item._id}}">
                <text class="btn-icon">✕</text>
                <text class="btn-text">拒绝</text>
              </button>
              <button class="btn-task-confirm" catchtap="confirmTask" data-id="{{item._id}}">
                <text class="btn-icon">✓</text>
                <text class="btn-text">确认</text>
              </button>
            </view>
          </view>
        </view>
      </scroll-view>
      
      <view class="modal-btns" wx:if="{{pendingTasks.length > 0}}">
        <button class="btn-secondary" bindtap="hideTaskDialog">关闭</button>
        <button class="btn-primary" bindtap="confirmAllTasks">一键确认全部</button>
      </view>
      <view class="modal-btns" wx:else>
        <button class="btn-secondary" bindtap="hideTaskDialog">关闭</button>
      </view>
    </view>
  </view>
</view>
