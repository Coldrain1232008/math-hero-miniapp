/* pages/create-character/create-character.wxss */
.create-container {
  min-height: 100vh;
  padding: 60rpx 40rpx 80rpx;
}

.step-wrap { display: flex; flex-direction: column; align-items: center; }

.step-title { text-align: center; margin-bottom: 60rpx; }
.step-num { font-size: 24rpx; color: rgba(255,255,255,0.4); display: block; margin-bottom: 12rpx; }
.step-heading { font-size: 52rpx; font-weight: bold; color: #fff; display: block; margin-bottom: 16rpx; }
.step-desc { font-size: 26rpx; color: rgba(255,255,255,0.6); display: block; }

/* 头像选择 */
.avatar-section {
  width: 100%;
  margin-bottom: 48rpx;
}

.section-title {
  color: rgba(255,255,255,0.7);
  font-size: 28rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.avatar-list {
  width: 100%;
  white-space: nowrap;
  display: flex;
  gap: 20rpx;
  padding: 10rpx 0;
}

.avatar-item {
  flex-shrink: 0;
  width: 100rpx;
  height: 100rpx;
}

.avatar-circle {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.avatar-item.selected .avatar-circle {
  border-color: #6c63ff;
  box-shadow: 0 0 20rpx rgba(108,99,255,0.5);
  transform: scale(1.1);
}

.avatar-icon { font-size: 52rpx; }

/* 性别 */
.gender-row {
  display: flex;
  gap: 32rpx;
  margin-bottom: 48rpx;
}

.gender-btn {
  padding: 16rpx 56rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  color: rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.08);
  border: 2rpx solid transparent;
}

.gender-btn.active {
  border-color: #6c63ff;
  color: #fff;
  background: rgba(108,99,255,0.3);
}

/* 名字输入 */
.name-area { width: 100%; margin-bottom: 60rpx; }

.name-input {
  width: 100%;
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.25);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  font-size: 36rpx;
  color: #fff;
  text-align: center;
  letter-spacing: 4rpx;
}

.next-btn { width: 80%; }
.next-btn.disabled { opacity: 0.5; }

/* 天赋大类选择 */
.category-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 48rpx;
}

.category-card {
  border: 3rpx solid transparent;
  border-radius: 20rpx;
  padding: 32rpx;
  background: rgba(255,255,255,0.06);
  transition: all 0.2s;
}

.category-card.selected {
  border-width: 3rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.category-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.category-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.category-name {
  font-size: 36rpx;
  font-weight: bold;
}

.category-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  display: block;
  margin-bottom: 20rpx;
}

.category-features {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.feature-tag {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  background: rgba(255,255,255,0.1);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

/* 天赋揭示 */
.talent-egg {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 60rpx 0;
}

.egg-glow {
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(108,99,255,0.4), transparent);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.egg-glow.rolling {
  animation: glow-spin 0.6s linear infinite;
}

@keyframes glow-spin {
  from { transform: scale(1); }
  50% { transform: scale(1.15); }
  to { transform: scale(1); }
}

.egg-icon { font-size: 120rpx; }
.egg-hint { color: rgba(255,255,255,0.6); font-size: 28rpx; }

/* 天赋卡片 */
.talent-reveal { width: 100%; }

.talent-badge {
  border: 2rpx solid;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 40rpx;
}

.talent-category { font-size: 24rpx; display: block; margin-bottom: 12rpx; }
.talent-name { font-size: 44rpx; font-weight: bold; color: #fff; display: block; margin-bottom: 16rpx; }
.talent-desc { font-size: 26rpx; color: rgba(255,255,255,0.7); display: block; }

/* 属性预览 */
.attrs-preview {
  background: rgba(255,255,255,0.06);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.attrs-title {
  color: rgba(255,255,255,0.5);
  font-size: 24rpx;
  margin-bottom: 24rpx;
  display: block;
}

.attr-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.attr-label {
  width: 80rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.attr-bar-bg {
  flex: 1;
  height: 12rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 6rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.attr-bar-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.attr-val {
  width: 48rpx;
  text-align: right;
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

/* 操作按钮 */
.create-actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  align-items: center;
}

.reroll-btn { width: 80%; }
.confirm-btn { width: 80%; }
