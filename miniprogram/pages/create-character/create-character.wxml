<!-- pages/create-character/create-character.wxml -->
<view class="create-container gradient-bg">

  <!-- 步骤一：基本信息 -->
  <view wx:if="{{step === 1}}" class="step-wrap">
    <view class="step-title">
      <text class="step-num">1 / 2</text>
      <text class="step-heading">创建你的英雄</text>
      <text class="step-desc">为你的角色取一个响亮的名字</text>
    </view>

    <!-- 头像选择 -->
    <view class="avatar-section">
      <view class="section-title">选择头像</view>
      <view class="avatar-grid">
        <view
          wx:for="{{avatarList}}"
          wx:key="id"
          class="avatar-item {{selectedAvatar === item.id ? 'selected' : ''}}"
          bindtap="selectAvatar"
          data-id="{{item.id}}"
        >
          <view class="avatar-circle" style="background-color: {{item.color}}">
            <text class="avatar-icon">{{item.icon}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 性别 -->
    <view class="gender-row">
      <view class="gender-btn {{gender === 'male' ? 'active' : ''}}" bindtap="setMale">⚔️ 男</view>
      <view class="gender-btn {{gender === 'female' ? 'active' : ''}}" bindtap="setFemale">✨ 女</view>
    </view>

    <!-- 名字输入 -->
    <view class="name-area">
      <input
        class="name-input"
        placeholder="输入角色名（2-8字）"
        maxlength="8"
        value="{{heroName}}"
        bindinput="onNameInput"
      />
    </view>

    <button class="btn-primary next-btn" bindtap="toStep2">下一步 →</button>
  </view>

  <!-- 步骤二：选择天赋大类 -->
  <view wx:if="{{step === 2}}" class="step-wrap">
    <view class="step-title">
      <text class="step-num">2 / 3</text>
      <text class="step-heading">选择你的天赋方向</text>
      <text class="step-desc">选择最符合你学习风格的方向</text>
    </view>

    <view class="category-list">
      <view
        wx:for="{{talentCategories}}"
        wx:key="id"
        class="category-card {{selectedCategory === item.id ? 'selected' : ''}}"
        bindtap="selectCategory"
        data-id="{{item.id}}"
        style="border-color: {{selectedCategory === item.id ? item.color : 'transparent'}}; background: {{selectedCategory === item.id ? item.color + '18' : '#ffffff18'}}"
      >
        <view class="category-header">
          <text class="category-icon" style="background: {{item.color}}20; color: {{item.color}}">
            {{item.id === 'A' ? '🔍' : item.id === 'B' ? '⚒️' : item.id === 'C' ? '🧵' : item.id === 'D' ? '🛡️' : item.id === 'E' ? '💡' : '⚡'}}
          </text>
          <text class="category-name" style="color: {{item.color}}">{{item.name}}</text>
        </view>
        <text class="category-desc">{{item.desc}}</text>
        <view class="category-features">
          <text class="feature-tag" wx:for="{{item.subtypes}}" wx:key="id" wx:for-item="sub">{{sub.name}}</text>
        </view>
      </view>
    </view>

    <button class="btn-primary next-btn {{!selectedCategory ? 'disabled' : ''}}" bindtap="toStep3">
      {{selectedCategory ? '下一步 →' : '请先选择天赋方向'}}
    </button>
  </view>

  <!-- 步骤三：天赋揭晓 -->
  <view wx:if="{{step === 3}}" class="step-wrap">
    <view class="step-title">
      <text class="step-num">3 / 3</text>
      <text class="step-heading">天赋觉醒</text>
      <text class="step-desc">系统正在为你随机解析具体天赋类型</text>
    </view>

    <view wx:if="{{!revealed}}" class="talent-egg" bindtap="revealTalent">
      <view class="egg-glow {{rolling ? 'rolling' : ''}}">
        <text class="egg-icon">🔮</text>
      </view>
      <text class="egg-hint">点击解析天赋</text>
    </view>

    <view wx:if="{{revealed && talent}}" class="talent-reveal">
      <view class="talent-badge" style="border-color:{{talent.color}}; background: {{talent.color}}18;">
        <text class="talent-category" style="color:{{talent.color}}">【{{talent.categoryName}}】</text>
        <text class="talent-name">{{talent.name}}</text>
        <text class="talent-desc">{{talent.desc}}</text>
      </view>

      <view class="attrs-preview">
        <text class="attrs-title">初始属性</text>
        <view class="attr-rows">
          <view wx:for="{{attrNames}}" wx:key="*this" class="attr-row">
            <text class="attr-label">{{item}}</text>
            <view class="attr-bar-bg">
              <view class="attr-bar-fill" style="width:{{talent.baseAttrs[index]/20*100}}%;background:{{attrColors[index]}}"></view>
            </view>
            <text class="attr-val">{{talent.baseAttrs[index]}}</text>
          </view>
        </view>
      </view>

      <view class="create-actions">
        <button class="btn-secondary reroll-btn" bindtap="reroll" wx:if="{{rerollCount > 0}}">
          重新随机（剩{{rerollCount}}次）
        </button>
        <button class="btn-primary confirm-btn" bindtap="confirmCreate" loading="{{creating}}">
          确认创建 ⚔️
        </button>
      </view>
    </view>
  </view>

</view>
