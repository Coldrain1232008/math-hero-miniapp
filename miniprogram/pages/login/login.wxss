/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  position: relative;
  overflow: hidden;
}

/* 背景光晕装饰 */
.bg-glow {
  position: fixed;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}
.bg-glow-1 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(108,99,255,0.25) 0%, transparent 70%);
  top: -160rpx;
  right: -160rpx;
}
.bg-glow-2 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(168,85,247,0.2) 0%, transparent 70%);
  bottom: -100rpx;
  left: -100rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 72rpx;
  position: relative;
  z-index: 1;
}

/* 徽章式 logo */
.logo-emblem {
  position: relative;
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
}

.emblem-ring {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(108,99,255,0.5);
  animation: ring-pulse 3s ease-in-out infinite;
}
.emblem-ring-outer {
  width: 180rpx;
  height: 180rpx;
  border-color: rgba(108,99,255,0.35);
  animation-delay: 0s;
}
.emblem-ring-inner {
  width: 140rpx;
  height: 140rpx;
  background: rgba(108,99,255,0.18);
  border-color: rgba(108,99,255,0.6);
  animation-delay: 0.5s;
}
@keyframes ring-pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.06); opacity: 0.7; }
}

.logo-icon {
  font-size: 80rpx;
  position: relative;
  z-index: 1;
  filter: drop-shadow(0 0 12rpx rgba(108,99,255,0.8));
}

/* 标题区 */
.title-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.app-title {
  font-size: 50rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 6rpx;
  text-shadow: 0 0 24rpx rgba(108,99,255,0.8), 0 2rpx 8rpx rgba(0,0,0,0.4);
}

/* 标题装饰线 */
.title-deco {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}
.deco-line {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(108,99,255,0.8), transparent);
}
.deco-star {
  font-size: 22rpx;
  color: rgba(168,85,247,0.9);
}

.app-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.55);
  letter-spacing: 4rpx;
}

.form-area {
  background: rgba(255,255,255,0.08);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  width: 100%;
  border: 1rpx solid rgba(255,255,255,0.15);
  position: relative;
  z-index: 1;
  backdrop-filter: blur(8px);
}

.input-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 16rpx;
  display: block;
}

.input-field {
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.2);
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #fff;
  width: 100%;
  margin-bottom: 40rpx;
}

.role-switch {
  display: flex;
  background: rgba(0,0,0,0.2);
  border-radius: 50rpx;
  padding: 6rpx;
  margin-bottom: 48rpx;
}

.role-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
  transition: all 0.2s;
}

.role-btn.active {
  background: #6c63ff;
  color: #fff;
  font-weight: 600;
}

.login-btn {
  width: 100%;
  text-align: center;
}

.hint {
  font-size: 24rpx;
  color: rgba(255,255,255,0.35);
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
}
