/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
}

.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  background: rgba(108,99,255,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  border: 2rpx solid rgba(108,99,255,0.6);
}

.logo-icon {
  font-size: 80rpx;
}

.app-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 8rpx;
}

.app-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 12rpx;
  letter-spacing: 2rpx;
}

.form-area {
  background: rgba(255,255,255,0.08);
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  width: 100%;
  border: 1rpx solid rgba(255,255,255,0.15);
}

.input-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 16rpx;
  display: block;
}

.input-field {
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.2);
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #fff;
  width: 100%;
  margin-bottom: 40rpx;
}

.role-switch {
  display: flex;
  background: rgba(0,0,0,0.2);
  border-radius: 50rpx;
  padding: 6rpx;
  margin-bottom: 48rpx;
}

.role-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
  transition: all 0.2s;
}

.role-btn.active {
  background: #6c63ff;
  color: #fff;
  font-weight: 600;
}

.login-btn {
  width: 100%;
  text-align: center;
}

.hint {
  font-size: 24rpx;
  color: rgba(255,255,255,0.35);
  margin-top: 40rpx;
}
