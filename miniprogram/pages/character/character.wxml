<!-- pages/character/character.wxml -->
<view class="page-bg">

  <!-- 顶部英雄卡片 -->
  <view class="hero-card gradient-bg">
    <view class="hero-header">
      <view class="hero-avatar-wrap">
        <view class="hero-avatar-circle" style="background-color: {{avatarInfo.color}}">
          <text class="hero-avatar-icon">{{avatarInfo.icon}}</text>
        </view>
        <view class="level-badge">Lv.{{levelInfo.level}}</view>
      </view>
      <view class="hero-info">
        <text class="hero-name">{{student.heroName}}</text>
        <view class="talent-tag" style="border-color:{{student.talentColor}};color:{{student.talentColor}}">
          {{student.talentName}}
        </view>
        <text class="hero-exp">累计经验：{{student.totalExp}} EXP</text>
      </view>
    </view>

    <!-- 经验条 -->
    <view wx:if="{{levelInfo.level < 100}}" class="exp-bar-wrap">
      <view class="exp-bar-label">
        <text>距离 Lv.{{levelInfo.level + 1}}</text>
        <text>{{levelInfo.progressExp}} / {{levelInfo.needExp}}</text>
      </view>
      <view class="exp-bar-bg">
        <view class="exp-bar-fill" style="width:{{levelInfo.percent}}%"></view>
      </view>
    </view>
    <view wx:else class="exp-bar-wrap">
      <text class="max-level-text">🏆 满级英雄</text>
    </view>
  </view>

  <!-- 雷达图 + 属性 -->
  <view class="card attrs-card">
    <view class="card-title">属性面板</view>
    <view class="radar-container">
      <radar-chart
        attrs="{{attrs}}"
        maxVal="{{maxAttrVal}}"
        size="{{260}}"
        mainColor="{{student.talentColor || '#6c63ff'}}"
      />
    </view>

    <!-- 六属性详细 -->
    <view class="attr-list">
      <view wx:for="{{attrDetail}}" wx:key="name" class="attr-item">
        <text class="attr-dot" style="background:{{item.color}}"></text>
        <text class="attr-name">{{item.name}}</text>
        <view class="attr-bar-bg">
          <view class="attr-bar" style="width:{{item.percent}}%;background:{{item.color}}"></view>
        </view>
        <text class="attr-num">{{item.val}}</text>
      </view>
    </view>

    <!-- 天赋成长率提示 -->
    <view class="growth-hint">
      <text class="growth-title">天赋成长率（每升一级）</text>
      <view class="growth-list">
        <view wx:for="{{growthDetail}}" wx:key="name" class="growth-item">
          <text style="color:{{item.color}}">{{item.name}}</text>
          <text class="growth-val">+{{item.val}}/级</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 每日任务卡片 -->
  <view class="card task-card">
    <view class="card-title">
      <text>今日任务</text>
      <text class="task-refresh-count" wx:if="{{dailyTask && dailyTask.refreshCount < 3}}">可刷新 {{3 - dailyTask.refreshCount}} 次</text>
    </view>
    
    <view wx:if="{{taskLoading}}" class="task-loading">
      <text>加载中...</text>
    </view>
    
    <view wx:elif="{{!dailyTask}}" class="task-empty">
      <text>暂无任务</text>
    </view>
    
    <view wx:else class="task-content">
      <view class="task-header">
        <text class="task-title">{{dailyTask.title}}</text>
        <view class="task-tags">
          <text class="task-tag preference" wx:if="{{dailyTask.isPreference}}">偏好任务 +5</text>
          <text class="task-tag exp">+{{dailyTask.expReward}} EXP</text>
        </view>
      </view>
      <text class="task-desc">{{dailyTask.desc}}</text>
      
      <view class="task-actions">
        <button 
          class="task-btn refresh" 
          bindtap="refreshTask" 
          disabled="{{dailyTask.refreshCount >= 3 || dailyTask.status !== 'pending'}}"
          wx:if="{{dailyTask.status === 'pending'}}"
        >
          🔄 刷新
        </button>
        <button 
          class="task-btn submit {{dailyTask.status !== 'pending' ? 'disabled' : ''}}" 
          bindtap="submitTask"
          disabled="{{dailyTask.status !== 'pending'}}"
        >
          {{dailyTask.status === 'pending' ? '✅ 完成任务' : dailyTask.status === 'submitted' ? '⏳ 等待确认' : '✓ 已完成'}}
        </button>
      </view>
    </view>
  </view>

  <!-- 徽章展示 -->
  <view class="card badge-card" wx:if="{{badges.length > 0}}">
    <view class="card-title">我的徽章</view>
    <view class="badge-list">
      <view wx:for="{{badges}}" wx:key="badgeId" class="badge-item">
        <view class="badge-icon">{{item.icon}}</view>
        <text class="badge-name">{{item.levelName}}</text>
        <text class="badge-streak">{{item.currentStreak}}天</text>
      </view>
    </view>
  </view>

  <!-- 重置天赋（如果有机会） -->
  <view wx:if="{{student.rerollChances > 0}}" class="card reroll-card" bindtap="onReroll">
    <text class="reroll-icon">🎲</text>
    <view class="reroll-info">
      <text class="reroll-title">重置天赋机会</text>
      <text class="reroll-desc">你还有 {{student.rerollChances}} 次重置机会，点击重新随机天赋</text>
    </view>
    <text class="reroll-arrow">›</text>
  </view>

  <!-- 经验记录 -->
  <view class="card log-card">
    <view class="card-title">最近经验记录</view>
    <view wx:if="{{expLogs.length === 0}}" class="empty-log">
      <text>暂无记录，等老师给你打第一分 ⚡</text>
    </view>
    <view wx:for="{{expLogs}}" wx:key="_id" class="log-item">
      <view class="log-left">
        <text class="log-type">{{item.typeLabel}}</text>
        <text class="log-desc">{{item.desc}}</text>
      </view>
      <view class="log-right">
        <text class="log-exp">+{{item.exp}} EXP</text>
        <text class="log-time">{{item.timeStr}}</text>
      </view>
    </view>
  </view>

</view>
