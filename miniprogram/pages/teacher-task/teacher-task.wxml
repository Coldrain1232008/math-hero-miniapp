<!-- pages/teacher-task/teacher-task.wxml -->
<view class="page-bg">

  <!-- Tab导航 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">
      <text class="tab-icon">⭐</text>
      <text class="tab-text">特殊任务</text>
    </view>
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
      <text class="tab-icon">📋</text>
      <text class="tab-text">任务池</text>
    </view>
    <view class="tab-item {{currentTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">
      <text class="tab-icon">👥</text>
      <text class="tab-text">学生任务</text>
    </view>
  </view>

  <!-- ========== Tab 0: 特殊任务 ========== -->
  <view class="tab-content" wx:if="{{currentTab === 0}}">
    <view class="section-title">当前特殊任务</view>

    <view wx:if="{{specialTask}}" class="special-card">
      <view class="special-badge">⭐ 特殊任务</view>
      <view class="special-title">{{specialTask.title}}</view>
      <view class="special-desc">{{specialTask.desc}}</view>
      <view class="special-reward">
        <text class="reward-icon">💎</text>
        <text class="reward-value">+{{specialTask.expReward || 20}} EXP</text>
      </view>
      <view class="special-actions">
        <button class="btn-edit" bindtap="showEditSpecial">编辑</button>
        <button class="btn-delete" bindtap="deleteSpecial">删除</button>
      </view>
    </view>

    <view wx:else class="empty-special">
      <text class="empty-icon">🌟</text>
      <text class="empty-text">暂无特殊任务</text>
      <text class="empty-hint">发布一个特殊任务，所有学生会优先收到这个任务</text>
    </view>

    <view class="btn-add-special" bindtap="showAddSpecial">
      <text wx:if="{{specialTask}}">✨ 更新特殊任务</text>
      <text wx:else>✨ 发布特殊任务</text>
    </view>

    <!-- 历史记录按钮 -->
    <view class="history-toggle" bindtap="toggleHistory">
      <text>📜 {{showHistory ? '收起历史' : '查看历史记录'}}</text>
    </view>

    <!-- 历史记录列表 -->
    <view wx:if="{{showHistory}}" class="history-section">
      <view class="section-title">发布历史</view>
      <view wx:if="{{specialTaskHistory.length === 0}}" class="empty-section">
        <text>暂无发布记录</text>
      </view>
      <view wx:for="{{specialTaskHistory}}" wx:key="_id" class="history-item">
        <view class="history-badge {{item.status}}">{{item.status === 'active' ? '当前' : item.status === 'expired' ? '已过期' : '已删除'}}</view>
        <view class="history-title">{{item.title}}</view>
        <view class="history-desc">{{item.desc}}</view>
        <view class="history-meta">
          <text class="history-time">{{item.createTimeStr}}</text>
          <text class="history-reward">+{{item.expReward || 20}} EXP</text>
        </view>
      </view>
    </view>

    <view class="info-card">
      <view class="info-title">特殊任务说明</view>
      <view class="info-item">• 特殊任务会固定在学生任务列表第一位</view>
      <view class="info-item">• 学生刷新普通任务时，特殊任务不会被刷新</view>
      <view class="info-item">• 特殊任务奖励建议设置高于普通任务</view>
      <view class="info-item">• 同时只能存在一个有效特殊任务</view>
    </view>
  </view>

  <!-- ========== Tab 1: 普通任务池 ========== -->
  <view class="tab-content" wx:if="{{currentTab === 1}}">
    <!-- 自定义任务 -->
    <view class="section-title">
      <text>自定义任务</text>
      <view class="btn-add-sm" bindtap="showAddCustom">+ 添加</view>
    </view>

    <view wx:if="{{customTasks.length === 0}}" class="empty-section">
      <text>暂无自定义任务</text>
    </view>

    <view wx:for="{{customTasks}}" wx:key="_id" class="custom-task-card">
      <view class="custom-task-content">
        <view class="custom-task-header">
          <view class="custom-task-title">{{item.title}}</view>
          <view class="custom-task-tag {{item.category}}">{{item.categoryName || '通用'}}</view>
        </view>
        <view class="custom-task-desc">{{item.desc}}</view>
      </view>
      <view class="custom-task-actions">
        <view class="action-btn edit" bindtap="showEditCustom" data-id="{{item._id}}">编辑</view>
        <view class="action-btn delete" bindtap="deleteCustom" data-id="{{item._id}}">删除</view>
      </view>
    </view>

    <!-- 内置任务（只读） -->
    <view class="section-title mt30">内置任务（不可编辑）</view>
    <view class="task-count">共 {{builtinTasks.length}} 个任务</view>

    <view wx:for="{{builtinTasks}}" wx:key="id" class="task-item builtin">
      <view class="task-info">
        <view class="task-title">{{item.title}}</view>
        <view class="task-desc">{{item.desc}}</view>
        <view class="task-category {{item.category}}">{{item.category}}</view>
      </view>
    </view>
  </view>

  <!-- ========== Tab 2: 学生任务 ========== -->
  <view class="tab-content" wx:if="{{currentTab === 2}}">
    <view class="section-title">
      <text>学生任务状态</text>
      <view class="task-count">{{studentList.length}} 人</view>
    </view>

    <view wx:if="{{studentList.length === 0}}" class="empty-section">
      <text>暂无学生数据</text>
    </view>

    <view wx:for="{{studentList}}" wx:key="studentId" class="student-card">
      <view class="student-info">
        <view class="student-name-row">
          <text class="student-name">{{item.studentName}}</text>
          <text class="student-code" wx:if="{{item.studentCode}}">{{item.studentCode}}</text>
        </view>
        <view class="student-status-row">
          <text class="status-tag {{item.statusClass}}">{{item.statusText}}</text>
          <text class="task-preview" wx:if="{{item.taskTitle}}">{{item.taskTitle}}</text>
          <text class="task-preview none" wx:else>暂无任务</text>
        </view>
      </view>
      <view class="student-actions">
        <button class="btn-grant" bindtap="showGrantMenu" data-studentid="{{item.studentId}}" data-name="{{item.studentName}}">发放</button>
        <button class="btn-reset" bindtap="resetStudentTask" data-studentid="{{item.studentId}}" data-name="{{item.studentName}}">重置</button>
      </view>
    </view>

    <!-- 发放道具菜单 -->
    <view wx:if="{{showGrantMenu}}" class="modal-mask" bindtap="hideGrantMenu">
      <view class="modal-box grant-modal" catchtap="preventBubble">
        <text class="modal-title">发放道具给 {{grantTargetName}}</text>

        <view class="grant-options">
          <view class="grant-item" bindtap="doGrant" data-action="challengeVoucher">
            <text class="grant-icon">⚔️</text>
            <text class="grant-name">挑战凭证</text>
            <text class="grant-hint">挑战同学时消耗</text>
          </view>
          <view class="grant-item" bindtap="doGrant" data-action="growthAccelerant">
            <text class="grant-icon">⚡</text>
            <text class="grant-name">成长加速剂</text>
            <text class="grant-hint">永久提升属性成长</text>
          </view>
          <view class="grant-item" bindtap="doGrant" data-action="addDraws">
            <text class="grant-icon">🎰</text>
            <text class="grant-name">增加抽卡次数</text>
            <text class="grant-hint">叠加到今日剩余次数</text>
          </view>
          <view class="grant-item" bindtap="doGrant" data-action="resetDraws">
            <text class="grant-icon">🔄</text>
            <text class="grant-name">重置抽卡次数</text>
            <text class="grant-hint">设为3次（当日有效）</text>
          </view>
        </view>

        <view class="grant-count-section">
          <text class="form-label">数量</text>
          <view class="grant-count-row">
            <text class="grant-count-btn" bindtap="adjustGrantCount" data delta="-5">-5</text>
            <text class="grant-count-btn" bindtap="adjustGrantCount" data-delta="-1">-1</text>
            <text class="grant-count-num">{{grantCount}}</text>
            <text class="grant-count-btn" bindtap="adjustGrantCount" data-delta="1">+1</text>
            <text class="grant-count-btn" bindtap="adjustGrantCount" data-delta="5">+5</text>
          </view>
        </view>

        <view class="modal-btns">
          <button class="btn-secondary" bindtap="hideGrantMenu">取消</button>
        </view>
      </view>
    </view>

    <view class="btn-reset-all" wx:if="{{studentList.length > 0}}" bindtap="resetAllTasks">
      重置全班任务
    </view>
  </view>

  <!-- ========== 特殊任务编辑弹窗 ========== -->
  <view wx:if="{{showSpecialEdit}}" class="modal-mask" bindtap="hideSpecialEdit">
    <view class="modal-box" catchtap="preventBubble">
      <text class="modal-title">{{editingSpecialId ? '编辑特殊任务' : '发布特殊任务'}}</text>
      
      <view class="form-item">
        <text class="form-label">任务标题</text>
        <input
          class="form-input"
          placeholder="例如：本周挑战：解答一道奥数题"
          value="{{specialForm.title}}"
          bindinput="onSpecialTitleInput"
          maxlength="30"
        />
      </view>

      <view class="form-item">
        <text class="form-label">任务描述</text>
        <textarea
          class="form-textarea"
          placeholder="详细描述学生需要完成的任务内容..."
          value="{{specialForm.desc}}"
          bindinput="onSpecialDescInput"
          maxlength="200"
        />
      </view>

      <view class="form-item">
        <text class="form-label">奖励经验值</text>
        <input
          class="form-input"
          type="number"
          placeholder="默认20"
          value="{{specialForm.expReward}}"
          bindinput="onSpecialRewardChange"
        />
        <text class="form-hint">建议高于普通任务（10-15 EXP）</text>
      </view>

      <view class="modal-btns">
        <button class="btn-secondary" bindtap="hideSpecialEdit">取消</button>
        <button class="btn-primary" bindtap="saveSpecial">保存</button>
      </view>
    </view>
  </view>

  <!-- ========== 自定义任务编辑弹窗 ========== -->
  <view wx:if="{{showCustomEdit}}" class="modal-mask" bindtap="hideCustomEdit">
    <view class="modal-box" catchtap="preventBubble">
      <text class="modal-title">{{editingCustomId ? '编辑任务' : '添加自定义任务'}}</text>
      
      <view class="form-item">
        <text class="form-label">任务标题</text>
        <input
          class="form-input"
          placeholder="简短的任务标题"
          value="{{customForm.title}}"
          bindinput="onCustomTitleInput"
          maxlength="30"
        />
      </view>

      <view class="form-item">
        <text class="form-label">任务描述</text>
        <textarea
          class="form-textarea"
          placeholder="详细描述任务内容..."
          value="{{customForm.desc}}"
          bindinput="onCustomDescInput"
          maxlength="200"
        />
      </view>

      <view class="form-item">
        <text class="form-label">职业分类</text>
        <picker
          mode="selector"
          range="{{categoryOptions}}"
          range-key="name"
          value="{{customForm.categoryIndex}}"
          bindchange="onCustomCategoryChange"
        >
          <view class="picker-value">
            {{categoryOptions[customForm.categoryIndex >= 0 ? customForm.categoryIndex : 6].name}}
          </view>
        </picker>
      </view>

      <view class="modal-btns">
        <button class="btn-secondary" bindtap="hideCustomEdit">取消</button>
        <button class="btn-primary" bindtap="saveCustom">保存</button>
      </view>
    </view>
  </view>

</view>
