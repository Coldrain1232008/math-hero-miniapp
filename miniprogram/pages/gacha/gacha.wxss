/* miniprogram/pages/gacha/gacha.wxss */
.page-bg { background: linear-gradient(160deg, #1a1a2e 0%, #16213e 100%); min-height: 100vh; }

/* 顶部卡片 */
.top-card {
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.gacha-title {
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 24rpx;
  letter-spacing: 4rpx;
}

.daily-info {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 20rpx;
}

.daily-label { font-size: 28rpx; color: rgba(255,255,255,0.6); }
.daily-num { font-size: 64rpx; font-weight: bold; color: #f6d365; }

.items-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.item-tag {
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.2);
  border-radius: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.item-tag.accel { border-color: rgba(245, 158, 11, 0.5); color: #f59e0b; }

.item-hint { font-size: 22rpx; color: rgba(255,255,255,0.4); }

/* 转盘区域 */
.gacha-area {
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 40rpx;
}

.gacha-btn-wrap {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6c63ff, #a78bfa);
  box-shadow: 0 0 60rpx rgba(108, 99, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.gacha-btn {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #a78bfa, #6c63ff);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.gacha-btn-wrap.disabled {
  opacity: 0.6;
  pointer-events: none;
}

.gacha-btn.drawing {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.gacha-btn-icon { font-size: 80rpx; }
.gacha-btn-text { font-size: 30rpx; color: #fff; font-weight: bold; letter-spacing: 2rpx; }

/* 规则说明 */
.gacha-rules {
  width: 100%;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
  border-radius: 24rpx;
  padding: 32rpx;
  box-sizing: border-box;
}

.rule-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
  text-align: center;
}

.rule-item {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
  line-height: 1.8;
}

.highlight { color: #f6d365; font-weight: bold; }

.rule-divider {
  height: 1rpx;
  background: rgba(255,255,255,0.1);
  margin: 20rpx 0;
}

.prize-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.prize-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  display: inline-block;
}

.prize-dot.exp { background: #10b981; }
.prize-dot.voucher { background: #a78bfa; }
.prize-dot.accel { background: #f59e0b; }

/* 结果弹窗 */
.result-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.result-card {
  width: 560rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 48rpx;
  text-align: center;
  animation: popIn 0.3s ease;
}

@keyframes popIn {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.result-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.result-title { font-size: 44rpx; font-weight: bold; color: #333; margin-bottom: 12rpx; }
.result-sub { font-size: 26rpx; color: #888; margin-bottom: 24rpx; }
.result-exp { font-size: 52rpx; font-weight: bold; color: #10b981; margin-bottom: 24rpx; }

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #6c63ff, #a78bfa);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: bold;
}

.btn-secondary {
  background: #f3f4f6;
  color: #666;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
}
