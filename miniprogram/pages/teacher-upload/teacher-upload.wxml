<!-- pages/teacher-upload/teacher-upload.wxml -->
<view class="page-bg">

  <!-- 说明 -->
  <view class="card intro-card">
    <view class="intro-icon">📊</view>
    <text class="intro-title">导入考试成绩</text>
    <text class="intro-desc">上传 Excel 文件，系统自动按排名发放经验值</text>
    <view class="exp-rule">
      <text class="rule-title">经验值规则（按班级排名）</text>
      <view class="rule-list">
        <view class="rule-item"><text>第 1 名</text><text class="rule-exp">150 EXP</text></view>
        <view class="rule-item"><text>中间</text><text class="rule-exp">线性递减</text></view>
        <view class="rule-item"><text>末名</text><text class="rule-exp">50 EXP</text></view>
      </view>
    </view>
  </view>

  <!-- Excel 格式要求 -->
  <view class="card format-card">
    <text class="format-title">📋 Excel 格式要求</text>
    <view class="format-row header-row">
      <text>学生姓名</text><text>分数</text>
    </view>
    <view class="format-row">
      <text class="gray">张三</text><text class="gray">92</text>
    </view>
    <view class="format-row">
      <text class="gray">李四</text><text class="gray">85</text>
    </view>
    <text class="format-hint">第一行为表头，姓名需与系统中的学生姓名完全一致</text>
  </view>

  <!-- 选择文件 -->
  <view class="card upload-card">
    <button class="btn-primary pick-btn" bindtap="pickFile">
      📂 选择 Excel 文件
    </button>

    <view wx:if="{{fileName}}" class="file-preview">
      <text class="file-icon">📄</text>
      <text class="file-name">{{fileName}}</text>
    </view>
  </view>

  <!-- 预览匹配结果 -->
  <view wx:if="{{preview.length > 0}}" class="card preview-card">
    <text class="preview-title">匹配预览（共 {{preview.length}} 条）</text>
    <view class="preview-row header">
      <text>学生</text><text>分数</text><text>排名</text><text>经验</text><text>状态</text>
    </view>
    <view
      wx:for="{{preview}}"
      wx:key="name"
      class="preview-row {{item.matched ? '' : 'unmatched'}}"
    >
      <text>{{item.name}}</text>
      <text>{{item.score}}</text>
      <text>{{item.matched ? '#' + item.rank : '-'}}</text>
      <text class="exp-num">{{item.matched ? '+' + item.exp : '-'}}</text>
      <text>{{item.matched ? '✅' : '❌未找到'}}</text>
    </view>

    <button
      class="btn-primary confirm-btn"
      bindtap="confirmImport"
      loading="{{importing}}"
      disabled="{{matchedCount === 0}}"
    >
      确认导入（{{matchedCount}} 人）
    </button>
  </view>

</view>
